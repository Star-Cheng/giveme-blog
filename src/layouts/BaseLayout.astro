---
import '../styles/global.css';
import SEO from '../components/seo/SEO.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
  publishDate?: Date;
}

const {
  title,
  description = '技术博客 - C++, ROS, Python',
  image,
  article = false,
  publishDate,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const navItems = [
  { href: `${base}`, label: '首页' },
  { href: `${base}blog`, label: '文章' },
  { href: `${base}about`, label: '关于' },
];
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      image={image}
      article={article}
      publishDate={publishDate}
    />
    <script is:inline>
      const theme = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <nav class="nav">
          <a href={`${base}`} class="logo">
            <span class="logo-main">RobotControl</span><span class="logo-accent">.dev</span>
          </a>
          <div class="nav-links">
            {navItems.map(item => (
              <a
                href={item.href}
                class:list={[
                  'nav-link',
                  item.href === `${base}`
                    ? currentPath === `${base}`
                    : currentPath.startsWith(item.href)
                    ? 'active'
                    : ''
                ]}
              >
                {item.label}
              </a>
            ))}
            <button class="theme-toggle" aria-label="切换主题">
              <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/>
                <line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/>
                <line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
              <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
              </svg>
            </button>
          </div>
        </nav>
      </div>
    </header>

    <main class="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; 2024 技术随笔. 使用 <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> 构建.</p>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector('.theme-toggle');
      toggle?.addEventListener('click', () => {
        const html = document.documentElement;
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    </script>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: var(--z-sticky);
        border-bottom: 1px solid rgba(74, 85, 104, 0.25);
        background: rgba(6, 10, 18, 0.9);
        backdrop-filter: blur(8px);
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 0;
      }

      .logo {
        font-family: var(--font-sans);
        font-size: 1.9rem;
        font-weight: 800;
        letter-spacing: -0.02em;
      }

      .logo-main { color: #f8fafc; }
      .logo-accent { color: #00d4a8; }

      .nav-links {
        display: flex;
        align-items: center;
        gap: var(--space-3);
      }

      .nav-link {
        color: #95a0b3;
        font-size: var(--text-sm);
        font-weight: 600;
        border: 1px solid transparent;
        border-radius: 999px;
        padding: 6px 12px;
        transition: all var(--duration-fast);
      }

      .nav-link:hover {
        color: #f8fafc;
        border-color: rgba(0, 212, 168, 0.45);
      }

      .nav-link.active {
        color: #00d4a8;
        border-color: rgba(0, 212, 168, 0.45);
        background: rgba(0, 212, 168, 0.08);
      }

      .theme-toggle {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        border: 1px solid rgba(90, 101, 126, 0.3);
        background: rgba(15, 23, 38, 0.55);
        color: #c7d1e1;
        cursor: pointer;
        transition: all var(--duration-fast);
      }

      .theme-toggle:hover {
        border-color: rgba(0, 212, 168, 0.45);
        color: #00d4a8;
      }

      .icon-sun { display: none; }
      .icon-moon { display: block; }
      [data-theme="light"] .icon-sun { display: block; }
      [data-theme="light"] .icon-moon { display: none; }

      .main-content {
        min-height: calc(100vh - 200px);
      }

      .site-footer {
        margin-top: var(--space-section);
        padding: var(--space-8) 0;
        border-top: 1px solid rgba(74, 85, 104, 0.25);
        text-align: center;
        color: #6f7a8f;
        font-size: var(--text-sm);
      }

      .site-footer a {
        color: #9aa3b5;
      }

      .site-footer a:hover {
        color: #00d4a8;
      }

      @media (max-width: 640px) {
        .nav-links {
          gap: 2px;
        }

        .logo {
          font-size: 1.45rem;
        }

        .nav-link {
          padding: 4px 10px;
        }
      }
    </style>
  </body>
</html>
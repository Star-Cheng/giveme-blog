---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = [...new Set(posts.flatMap(p => p.data.tags))];

  return tags.map(tag => ({
    params: { tag },
    props: { tag, posts },
  }));
}

const { tag, posts } = Astro.props;
const filteredPosts = posts
  .filter(p => p.data.tags.includes(tag))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={`标签: ${tag} - 技术随笔`}>
  <section class="tag-page">
    <div class="container">
      <header class="page-header">
        <div class="tag-badge">
          <span class="tag-icon">#</span>
          <h1 class="page-title">{tag}</h1>
        </div>
        <p class="page-subtitle">共 {filteredPosts.length} 篇文章</p>
      </header>

      <div class="post-list">
        {filteredPosts.map((post, index) => (
          <a
            href={`/blog/${post.id}`}
            class="post-item"
            style={`--delay: ${index * 0.1}s`}
          >
            <time class="post-date" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('zh-CN')}
            </time>
            <div class="post-info">
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tag-page {
    padding: var(--space-section) 0;
  }

  .page-header {
    margin-bottom: var(--space-12);
  }

  .tag-badge {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .tag-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--color-accent);
    color: white;
    border-radius: var(--radius-lg);
    font-size: var(--text-2xl);
    font-weight: 700;
  }

  .page-title {
    font-size: var(--text-4xl);
  }

  .page-subtitle {
    color: var(--color-text-subtle);
    font-size: var(--text-lg);
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .post-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: var(--space-8);
    padding: var(--space-6);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all var(--duration-normal) var(--ease-out-expo);
    opacity: 0;
    animation: fadeInUp 0.5s var(--ease-out-expo) var(--delay, 0s) forwards;
  }

  .post-item:hover {
    border-color: var(--color-accent);
    transform: translateX(8px);
  }

  .post-date {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
  }

  .post-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
    color: var(--color-text);
    transition: color var(--duration-fast);
  }

  .post-item:hover .post-title {
    color: var(--color-accent);
  }

  .post-desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .post-item {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const allTags = ['运动规划', '强化学习', 'Sim2Real', '机器人仿真'];
const base = import.meta.env.BASE_URL;

const tagCounts = allTags.reduce((acc, tag) => {
  acc[tag] = posts.filter(p => p.data.category === tag || p.data.tags.includes(tag)).length;
  return acc;
}, {} as Record<string, number>);
---

<BaseLayout title="标签 - 技术随笔">
  <section class="tags-page">
    <div class="container">
      <header class="page-header">
        <h1 class="page-title">所有标签</h1>
        <p class="page-subtitle">共 {allTags.length} 个标签</p>
      </header>

      <div class="tags-grid">
        {allTags.map((tag, index) => (
          <a
            href={`${base}tags/${tag}`}
            class="tag-card"
            style={`--delay: ${Math.min(index, 15) * 0.05}s`}
          >
            <span class="tag-name">{tag}</span>
            <span class="tag-count">{tagCounts[tag]} 篇</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tags-page {
    padding: var(--space-section) 0;
  }

  .page-header {
    margin-bottom: var(--space-12);
    text-align: center;
  }

  .page-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .page-subtitle {
    color: var(--color-text-subtle);
  }

  .tags-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-4);
  }

  .tag-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-5) var(--space-6);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all var(--duration-normal) var(--ease-out-expo);
    opacity: 0;
    animation: fadeInUp 0.5s var(--ease-out-expo) var(--delay, 0s) forwards;
  }

  .tag-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
    box-shadow: var(--shadow-glow);
  }

  .tag-name {
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-text);
  }

  .tag-card:hover .tag-name {
    color: var(--color-accent);
  }

  .tag-count {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="文章列表 - 技术随笔">
  <section class="blog-page">
    <div class="container">
      <header class="page-header">
        <h1 class="page-title">所有文章</h1>
        <p class="page-subtitle">共 {posts.length} 篇文章</p>
      </header>

      <div class="blog-layout">
        <aside class="sidebar">
          <h3 class="sidebar-title">标签筛选</h3>
          <div class="tag-list">
            <a href={`${base}blog`} class="tag-item active">全部</a>
            {allTags.map(tag => (
              <a href={`${base}tags/${tag}`} class="tag-item">{tag}</a>
            ))}
          </div>
        </aside>

        <main class="post-grid">
          {posts.map((post, index) => (
            <a
              href={`${base}blog/${post.id}`}
              class="post-card"
              style={`--delay: ${Math.min(index, 10) * 0.05}s`}
            >
              <div class="post-meta">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('zh-CN')}
                </time>
                <span class="reading-time">阅读</span>
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              <div class="post-tags">
                {post.data.tags.map(tag => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </main>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-page {
    padding: var(--space-section) 0;
  }

  .page-header {
    margin-bottom: var(--space-12);
    text-align: center;
  }

  .page-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .page-subtitle {
    color: var(--color-text-subtle);
  }

  .blog-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-12);
  }

  .sidebar {
    position: sticky;
    top: 100px;
    height: fit-content;
  }

  .sidebar-title {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-4);
  }

  .tag-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .tag-item {
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    transition: all var(--duration-fast);
    text-align: left;
  }

  .tag-item:hover,
  .tag-item.active {
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }

  .tag-item.active {
    color: var(--color-accent);
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  .post-card {
    display: block;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    transition: all var(--duration-normal) var(--ease-out-expo);
    opacity: 0;
    animation: fadeInUp 0.5s var(--ease-out-expo) var(--delay, 0s) forwards;
  }

  .post-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
    box-shadow: var(--shadow-glow);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
  }

  .reading-time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .post-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
    color: var(--color-text);
    transition: color var(--duration-fast);
  }

  .post-card:hover .post-title {
    color: var(--color-accent);
  }

  .post-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post-tag {
    padding: 2px 8px;
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  @media (max-width: 900px) {
    .blog-layout {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
      display: flex;
      gap: var(--space-4);
      overflow-x: auto;
      padding-bottom: var(--space-4);
    }

    .tag-list {
      flex-direction: row;
      flex-wrap: nowrap;
    }

    .tag-item {
      white-space: nowrap;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
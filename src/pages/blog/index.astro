---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="文章列表 - 技术随笔">
  <section class="blog-page">
    <div class="container">
      <header class="page-header">
        <h1 class="page-title">所有文章</h1>
        <p class="page-subtitle">共 {posts.length} 篇文章</p>
      </header>

      <div class="blog-layout">
        <aside class="sidebar">
          <h3 class="sidebar-title">筛选</h3>
          <label class="search-label" for="post-search">搜索标题 / 标签</label>
          <input id="post-search" class="search-input" type="search" placeholder="例如：ROS2 / 协程" />

          <div class="filter-meta">
            <span id="active-tag-count">已选标签：0</span>
            <button type="button" id="clear-filters" class="clear-btn">清空</button>
          </div>

          <div class="tag-list" id="tag-filters">
            {allTags.map(tag => (
              <button type="button" class="tag-item" data-tag={tag.toLowerCase()}>{tag}</button>
            ))}
          </div>
        </aside>

        <main class="post-grid" id="post-grid">
          {posts.map((post, index) => (
            <a
              href={`${base}blog/${post.id}`}
              class="post-card"
              data-post-card
              data-title={post.data.title.toLowerCase()}
              data-tags={post.data.tags.join(',').toLowerCase()}
              style={`--delay: ${Math.min(index, 10) * 0.05}s`}
            >
              <div class="post-meta">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('zh-CN')}
                </time>
                <span class="reading-time">阅读</span>
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              <div class="post-tags">
                {post.data.tags.map(tag => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
            </a>
          ))}
          <p id="empty-state" class="empty-state" hidden>没有匹配的文章，试试减少筛选条件。</p>
        </main>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const searchInput = document.querySelector('#post-search');
  const tagButtons = Array.from(document.querySelectorAll('#tag-filters .tag-item'));
  const clearButton = document.querySelector('#clear-filters');
  const postCards = Array.from(document.querySelectorAll('[data-post-card]'));
  const emptyState = document.querySelector('#empty-state');
  const activeTagCount = document.querySelector('#active-tag-count');
  const selectedTags = new Set();

  const updateUI = () => {
    const keyword = searchInput?.value.trim().toLowerCase() ?? '';

    let visibleCount = 0;
    postCards.forEach(card => {
      const title = card.getAttribute('data-title') || '';
      const tags = (card.getAttribute('data-tags') || '').split(',').filter(Boolean);
      const keywordMatch = !keyword || title.includes(keyword) || tags.some(tag => tag.includes(keyword));
      const tagMatch = selectedTags.size === 0 || [...selectedTags].every(tag => tags.includes(tag));
      const visible = keywordMatch && tagMatch;
      card.hidden = !visible;
      if (visible) visibleCount += 1;
    });

    if (emptyState) {
      emptyState.hidden = visibleCount > 0;
    }

    if (activeTagCount) {
      activeTagCount.textContent = `已选标签：${selectedTags.size}`;
    }
  };

  searchInput?.addEventListener('input', updateUI);

  tagButtons.forEach(button => {
    button.addEventListener('click', () => {
      const tag = button.getAttribute('data-tag');
      if (!tag) return;

      if (selectedTags.has(tag)) {
        selectedTags.delete(tag);
        button.classList.remove('active');
      } else {
        selectedTags.add(tag);
        button.classList.add('active');
      }
      updateUI();
    });
  });

  clearButton?.addEventListener('click', () => {
    selectedTags.clear();
    tagButtons.forEach(button => button.classList.remove('active'));
    if (searchInput) {
      searchInput.value = '';
    }
    updateUI();
  });
</script>

<style>
  .blog-page {
    padding: var(--space-section) 0;
  }

  .page-header {
    margin-bottom: var(--space-12);
    text-align: center;
  }

  .page-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .page-subtitle {
    color: var(--color-text-subtle);
  }

  .blog-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-12);
  }

  .sidebar {
    position: sticky;
    top: 100px;
    height: fit-content;
  }

  .sidebar-title {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-4);
  }

  .search-label {
    display: block;
    margin-bottom: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
  }

  .search-input {
    width: 100%;
    padding: var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .search-input::placeholder {
    color: var(--color-text-subtle);
  }

  .filter-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  .clear-btn {
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-subtle);
    border-radius: var(--radius-sm);
    padding: 2px 8px;
    cursor: pointer;
  }

  .clear-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag-item {
    border: 1px solid var(--color-border);
    background: transparent;
    cursor: pointer;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    transition: all var(--duration-fast);
  }

  .tag-item:hover,
  .tag-item.active {
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }

  .tag-item.active {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  .empty-state {
    grid-column: 1 / -1;
    padding: var(--space-8);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text-subtle);
    text-align: center;
  }

  .post-card {
    display: block;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    transition: all var(--duration-normal) var(--ease-out-expo);
    opacity: 0;
    animation: fadeInUp 0.5s var(--ease-out-expo) var(--delay, 0s) forwards;
  }

  .post-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
    box-shadow: var(--shadow-glow);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
  }

  .reading-time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .post-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
    color: var(--color-text);
    transition: color var(--duration-fast);
  }

  .post-card:hover .post-title {
    color: var(--color-accent);
  }

  .post-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post-tag {
    padding: 2px 8px;
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  @media (max-width: 900px) {
    .blog-layout {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
      display: flex;
      gap: var(--space-4);
      overflow-x: auto;
      padding-bottom: var(--space-4);
    }

    .tag-list {
      flex-wrap: nowrap;
      overflow-x: auto;
    }

    .tag-item {
      white-space: nowrap;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
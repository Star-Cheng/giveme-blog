---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = ['机械臂', '运动控制', '轨迹规划', '系统集成', '手眼标定', '标定算法', '视觉伺服', '误差建模', '奇异点', '阻尼最小二乘', '逆运动学'];
const allCategories = ['运动规划', '强化学习', 'Sim2Real', '机器人仿真'];
const allMonths = ['2026年4月'];
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="文章列表 - 技术随笔">
  <section class="blog-page">
    <div class="container">
      <header class="page-header">
        <h1 class="page-title">文章列表</h1>
        <p class="page-subtitle">共 {posts.length} 篇文章</p>
      </header>

      <div class="search-wrap">
        <input id="post-search" class="search-input" type="search" placeholder="搜索文章标题或标签..." />
      </div>

      <section class="filters-panel">
        <div class="filter-block">
          <h3>分类</h3>
          <div class="chip-row" id="category-filters">
            <button type="button" class="chip active" data-category="all">全部</button>
            {allCategories.map(cat => (
              <button type="button" class="chip" data-category={cat.toLowerCase()}>{cat}</button>
            ))}
          </div>
        </div>

        <div class="filter-block">
          <h3>归档</h3>
          <div class="chip-row" id="month-filters">
            <button type="button" class="chip active" data-month="all">全部</button>
            {allMonths.map(month => (
              <button type="button" class="chip" data-month={month}>{month}</button>
            ))}
          </div>
        </div>

        <div class="filter-block">
          <h3>标签</h3>
          <div class="chip-row chips-tags" id="tag-filters">
            {allTags.map(tag => (
              <button type="button" class="chip tag-chip" data-tag={tag.toLowerCase()}>{tag}</button>
            ))}
          </div>
        </div>
      </section>

      <p class="result-text" id="result-text">共找到 {posts.length} 篇文章</p>

      <main class="post-grid" id="post-grid">
        {posts.map((post, index) => {
          const postMonth = `${post.data.date.getFullYear()}年${post.data.date.getMonth() + 1}月`;
          const category = post.data.category ?? '运动规划';
          return (
            <a
              href={`${base}blog/${post.id}`}
              class="post-card"
              data-post-card
              data-title={post.data.title.toLowerCase()}
              data-tags={post.data.tags.join(',').toLowerCase()}
              data-category={category.toLowerCase()}
              data-month={postMonth}
              style={`--delay: ${Math.min(index, 12) * 0.04}s`}
            >
              <span class="card-category">{category}</span>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              <div class="post-tags">
                {post.data.tags.slice(0, 3).map(tag => (
                  <span class="post-tag">{tag}</span>
                ))}
                {post.data.tags.length > 3 && (
                  <span class="post-tag post-tag-extra">+{post.data.tags.length - 3}</span>
                )}
              </div>
              <div class="post-meta">
                <span>{post.data.date.toLocaleDateString('zh-CN')}</span>
                <span>·</span>
                <span>{post.data.readingMinutes} 分钟</span>
              </div>
            </a>
          );
        })}
        <p id="empty-state" class="empty-state" hidden>没有匹配的文章，请调整筛选条件。</p>
      </main>
    </div>
  </section>
</BaseLayout>

<script>
  const setupBlogFilters = () => {
    const blogPage = document.querySelector('.blog-page');
    if (!blogPage || blogPage.getAttribute('data-filters-ready') === 'true') return;
    blogPage.setAttribute('data-filters-ready', 'true');

    const searchInput = document.querySelector('#post-search');
    const postCards = Array.from(document.querySelectorAll('[data-post-card]'));
    const emptyState = document.querySelector('#empty-state');
    const resultText = document.querySelector('#result-text');

    const categoryButtons = Array.from(document.querySelectorAll('#category-filters .chip'));
    const monthButtons = Array.from(document.querySelectorAll('#month-filters .chip'));
    const tagButtons = Array.from(document.querySelectorAll('#tag-filters .chip'));

    if (!postCards.length) return;

    let selectedCategory = 'all';
    let selectedMonth = 'all';
    let selectedTag = 'all';

    const activateSingle = (buttons, activeButton) => {
      buttons.forEach(btn => btn.classList.remove('active'));
      activeButton.classList.add('active');
    };

    const updateUI = () => {
      const keyword = searchInput?.value.trim().toLowerCase() ?? '';
      let visibleCount = 0;

      postCards.forEach(card => {
        const title = card.getAttribute('data-title') || '';
        const tags = (card.getAttribute('data-tags') || '').split(',').filter(Boolean);
        const category = card.getAttribute('data-category') || '';
        const month = card.getAttribute('data-month') || '';

        const keywordMatch = !keyword || title.includes(keyword) || tags.some(tag => tag.includes(keyword));
        const categoryMatch = selectedCategory === 'all' || category === selectedCategory;
        const monthMatch = selectedMonth === 'all' || month === selectedMonth;
        const tagMatch = selectedTag === 'all' || tags.includes(selectedTag);

        const visible = keywordMatch && categoryMatch && monthMatch && tagMatch;
        card.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      if (emptyState) emptyState.hidden = visibleCount > 0;
      if (resultText) resultText.textContent = `共找到 ${visibleCount} 篇文章`;
    };

    categoryButtons.forEach(button => {
      button.addEventListener('click', () => {
        selectedCategory = button.getAttribute('data-category') || 'all';
        activateSingle(categoryButtons, button);
        updateUI();
      });
    });

    monthButtons.forEach(button => {
      button.addEventListener('click', () => {
        selectedMonth = button.getAttribute('data-month') || 'all';
        activateSingle(monthButtons, button);
        updateUI();
      });
    });

    tagButtons.forEach(button => {
      button.addEventListener('click', () => {
        const nextTag = button.getAttribute('data-tag') || 'all';
        const isSameTag = selectedTag === nextTag;
        selectedTag = isSameTag ? 'all' : nextTag;

        tagButtons.forEach(btn => btn.classList.remove('active'));
        if (!isSameTag) {
          button.classList.add('active');
        }
        updateUI();
      });
    });

    searchInput?.addEventListener('input', updateUI);
    updateUI();
  };

  document.addEventListener('DOMContentLoaded', setupBlogFilters);
  document.addEventListener('astro:page-load', setupBlogFilters);
</script>

<style>
  .blog-page {
    padding: var(--space-section) 0;
  }

  .page-header {
    margin-bottom: 18px;
  }

  .page-title {
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    margin-bottom: 6px;
  }

  .page-subtitle {
    color: #8f9ab0;
    margin: 0;
    font-size: 1.05rem;
  }

  .search-wrap {
    margin-bottom: 18px;
  }

  .search-input {
    width: 100%;
    border: 1px solid rgba(90, 101, 126, 0.35);
    border-radius: 16px;
    background: rgba(15, 23, 38, 0.78);
    color: #f3f7ff;
    padding: 14px 16px;
    font-size: 1rem;
  }

  .search-input::placeholder {
    color: #75829a;
  }

  .filters-panel {
    border: 1px solid rgba(58, 70, 92, 0.45);
    border-radius: 16px;
    background: linear-gradient(180deg, rgba(12, 19, 32, 0.9), rgba(10, 15, 26, 0.92));
    padding: 18px;
    display: grid;
    gap: 14px;
    margin-bottom: 16px;
  }

  .filter-block h3 {
    color: #7e8ba6;
    font-size: 0.9rem;
    margin-bottom: 10px;
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .chip {
    border: 1px solid rgba(90, 101, 126, 0.35);
    background: rgba(15, 22, 36, 0.75);
    color: #c6d0e1;
    border-radius: 999px;
    padding: 6px 12px;
    font-size: 0.86rem;
    cursor: pointer;
    transition: all .2s;
  }

  .chip:hover,
  .chip.active {
    border-color: rgba(0, 212, 168, 0.5);
    color: #00d4a8;
    background: rgba(0, 212, 168, 0.09);
  }

  .chips-tags .chip {
    font-size: 0.8rem;
    padding: 5px 10px;
  }

  .result-text {
    color: #8a96ae;
    margin: 0 0 16px;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .post-card {
    display: block;
    border: 1px solid rgba(58, 70, 92, 0.45);
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(12, 19, 32, 0.96), rgba(10, 15, 26, 0.96));
    padding: 18px;
    opacity: 0;
    animation: fadeInUp 0.45s ease var(--delay, 0s) forwards;
    transition: border-color .2s ease, transform .2s ease;
  }

  .post-card[hidden] {
    display: none !important;
  }

  .post-card:hover {
    border-color: rgba(0, 212, 168, 0.48);
    transform: translateY(-2px);
  }

  .card-category {
    display: inline-block;
    font-size: 0.74rem;
    color: #00d9ae;
    background: rgba(0, 212, 168, 0.09);
    border: 1px solid rgba(0, 212, 168, 0.24);
    border-radius: 999px;
    padding: 3px 10px;
    margin-bottom: 10px;
  }

  .post-title {
    font-size: clamp(1.2rem, 1.4vw, 1.65rem);
    line-height: 1.38;
    margin-bottom: 10px;
  }

  .post-desc {
    color: #90a0b9;
    font-size: 0.94rem;
    margin: 0;
    line-height: 1.7;
  }

  .post-tags {
    margin-top: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .post-tag {
    font-size: 0.73rem;
    color: #00d0a8;
    background: rgba(0, 212, 168, 0.08);
    border: 1px solid rgba(0, 212, 168, 0.22);
    border-radius: 999px;
    padding: 2px 8px;
  }

  .post-tag-extra {
    color: #99a5bc;
    border-color: rgba(90, 101, 126, 0.28);
    background: rgba(90, 101, 126, 0.08);
  }

  .post-meta {
    margin-top: 12px;
    display: flex;
    gap: 8px;
    color: #6f7d95;
    font-size: 0.8rem;
  }

  .empty-state {
    grid-column: 1 / -1;
    padding: var(--space-8);
    border: 1px dashed rgba(90, 101, 126, 0.35);
    border-radius: var(--radius-lg);
    color: #7f8ca5;
    text-align: center;
  }

  @media (max-width: 860px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import GiscusComments from '../../components/comments/GiscusComments.astro';
import ButtondownForm from '../../components/subscribe/ButtondownForm.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Calculate reading time
const words = post.body?.split(/\s+/).length || 0;
const readingTime = Math.ceil(words / 200);
const base = import.meta.env.BASE_URL;
const site = Astro.site ?? new URL('http://localhost:4321');
const articleUrl = new URL(Astro.url.pathname, site).toString();
const encodedUrl = encodeURIComponent(articleUrl);
const encodedTitle = encodeURIComponent(post.data.title);
const toSlug = (name: string) =>
  name
    .toLowerCase()
    .trim()
    .replace(/\s+/g, '-')
    .replace(/[^\w\u4e00-\u9fa5-]/g, '');

const allPosts = await getCollection('blog');
const seriesPosts = post.data.series
  ? allPosts
      .filter(p => !p.data.draft && p.data.series?.name === post.data.series?.name)
      .sort((a, b) => (a.data.series?.order ?? 0) - (b.data.series?.order ?? 0))
  : [];
const currentSeriesIndex = seriesPosts.findIndex(p => p.id === post.id);
const prevSeriesPost = currentSeriesIndex > 0 ? seriesPosts[currentSeriesIndex - 1] : null;
const nextSeriesPost =
  currentSeriesIndex >= 0 && currentSeriesIndex < seriesPosts.length - 1
    ? seriesPosts[currentSeriesIndex + 1]
    : null;
---

<BaseLayout
  title={`${post.data.title} - 技术随笔`}
  description={post.data.description}
  article={true}
  publishDate={post.data.date}
>
  <article class="post">
    <div class="container">
      <div class="post-layout">
        <main class="post-main">
          <header class="post-header">
            <div class="post-meta">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('zh-CN', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>
              <span class="separator">·</span>
              <span class="reading-time">{readingTime} 分钟阅读</span>
            </div>
            <h1 class="post-title">{post.data.title}</h1>
            <p class="post-desc">{post.data.description}</p>
            <div class="post-tags">
              {post.data.tags.map(tag => (
                <a href={`${base}tags/${tag}`} class="post-tag">{tag}</a>
              ))}
            </div>
            {post.data.series && (
              <a href={`${base}series/${toSlug(post.data.series.name)}`} class="series-chip">
                系列：{post.data.series.name} · 第 {post.data.series.order} 篇
              </a>
            )}
          </header>

          <div class="post-content">
            <Content />
          </div>

          <footer class="post-footer">
            <div class="post-nav">
              <a href={`${base}blog`} class="back-link">← 返回文章列表</a>
            </div>

            {post.data.series && (
              <section class="series-nav">
                <h3 class="series-title">系列阅读：{post.data.series.name}</h3>
                <div class="series-links">
                  {prevSeriesPost ? (
                    <a href={`${base}blog/${prevSeriesPost.id}`} class="series-link">
                      ← 上一篇：{prevSeriesPost.data.title}
                    </a>
                  ) : (
                    <span class="series-link disabled">← 已是系列第一篇</span>
                  )}
                  {nextSeriesPost ? (
                    <a href={`${base}blog/${nextSeriesPost.id}`} class="series-link">
                      下一篇：{nextSeriesPost.data.title} →
                    </a>
                  ) : (
                    <span class="series-link disabled">已是系列最后一篇 →</span>
                  )}
                </div>
              </section>
            )}

            <section class="share-section">
              <h3 class="share-title">分享到</h3>
              <div class="share-actions">
                <a
                  class="share-link"
                  href={`https://service.weibo.com/share/share.php?url=${encodedUrl}&title=${encodedTitle}`}
                  target="_blank"
                  rel="noopener"
                >
                  微博
                </a>
                <a
                  class="share-link"
                  href={`https://www.zhihu.com/share?url=${encodedUrl}&title=${encodedTitle}`}
                  target="_blank"
                  rel="noopener"
                >
                  知乎
                </a>
                <button class="share-link share-btn" data-copy-url={articleUrl} type="button">微信/复制链接</button>
              </div>
              <p class="share-tip" id="share-tip">点击“微信/复制链接”后会复制链接，便于转发到微信。</p>
            </section>
            <div class="subscribe-wrap">
              <ButtondownForm
                compact={true}
                title="喜欢这篇文章？"
                description="订阅后会收到同主题文章与系列更新提醒。"
              />
            </div>
            <GiscusComments />
          </footer>
        </main>

        <aside class="post-sidebar">
          <div class="sidebar-sticky">
            <div class="toc-card">
              <h4 class="toc-title">文章目录</h4>
              <div class="toc-content" id="toc-content">
                <!-- TOC will be generated by JS -->
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  // Generate TOC from headings
  const content = document.querySelector('.post-content');
  const tocContent = document.getElementById('toc-content');

  if (content && tocContent) {
    const headings = content.querySelectorAll('h2, h3');
    if (headings.length > 0) {
      const toc = document.createElement('ul');
      toc.className = 'toc-list';

      headings.forEach(heading => {
        const id = heading.textContent?.trim().toLowerCase().replace(/[\s\n]+/g, '-') || '';
        heading.id = id;

        const li = document.createElement('li');
        li.className = heading.tagName === 'H2' ? 'toc-item' : 'toc-item toc-item-sub';
        li.innerHTML = `<a href="#${id}">${heading.textContent}</a>`;
        toc.appendChild(li);
      });

      tocContent.appendChild(toc);
    } else {
      tocContent.innerHTML = '<p class="toc-empty">暂无目录</p>';
    }
  }

  // Highlight active section on scroll
  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          document.querySelectorAll('.toc-item a').forEach(a => {
            a.classList.toggle('active', a.getAttribute('href') === `#${id}`);
          });
        }
      });
    },
    { rootMargin: '-20% 0% -70% 0%' }
  );

  document.querySelectorAll('.post-content h2, .post-content h3').forEach(h => {
    observer.observe(h);
  });

  const copyButton = document.querySelector('.share-btn');
  const shareTip = document.querySelector('#share-tip');
  copyButton?.addEventListener('click', async () => {
    const url = copyButton.getAttribute('data-copy-url');
    if (!url) return;
    try {
      await navigator.clipboard.writeText(url);
      if (shareTip) shareTip.textContent = '链接已复制，可直接粘贴到微信或其他社交平台。';
    } catch {
      if (shareTip) shareTip.textContent = '复制失败，请手动复制当前页面地址。';
    }
  });
</script>

<style>
  .post {
    padding: var(--space-section) 0;
  }

  .post-layout {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: var(--space-12);
  }

  .post-main {
    min-width: 0;
  }

  .post-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
  }

  .separator {
    opacity: 0.5;
  }

  .post-title {
    font-size: clamp(var(--text-3xl), 3vw, var(--text-5xl));
    line-height: var(--leading-tight);
    margin-bottom: var(--space-6);
  }

  .post-desc {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .series-chip {
    display: inline-block;
    margin-top: var(--space-4);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .series-chip:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .post-tag {
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    transition: all var(--duration-fast);
  }

  .post-tag:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Post Content */
  .post-content {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  .post-content :global(h2) {
    font-size: var(--text-2xl);
    margin-top: var(--space-12);
    margin-bottom: var(--space-6);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .post-content :global(h3) {
    font-size: var(--text-xl);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .post-content :global(h4) {
    font-size: var(--text-lg);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  .post-content :global(p) {
    margin-bottom: var(--space-6);
    color: var(--color-text);
  }

  .post-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-content :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: var(--space-6);
    padding-left: var(--space-6);
  }

  .post-content :global(li) {
    margin-bottom: var(--space-3);
  }

  .post-content :global(pre) {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    overflow-x: auto;
    margin: var(--space-8) 0;
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-6);
    margin: var(--space-8) 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-8) 0;
  }

  .post-content :global(th),
  .post-content :global(td) {
    border: 1px solid var(--color-border);
    padding: var(--space-3) var(--space-4);
    text-align: left;
  }

  .post-content :global(th) {
    background: var(--color-bg-secondary);
    font-weight: 600;
  }

  .post-content :global(img) {
    border-radius: var(--radius-lg);
    margin: var(--space-8) 0;
  }

  /* Sidebar */
  .post-sidebar {
    position: relative;
  }

  .sidebar-sticky {
    position: sticky;
    top: 100px;
  }

  .toc-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .toc-title {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-4);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    margin-bottom: var(--space-2);
  }

  .toc-item-sub {
    padding-left: var(--space-4);
  }

  .toc-item :global(a) {
    display: block;
    padding: var(--space-2);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    transition: all var(--duration-fast);
  }

  .toc-item :global(a:hover),
  .toc-item :global(a.active) {
    background: var(--color-bg-tertiary);
    color: var(--color-accent);
  }

  .toc-empty {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
  }

  /* Footer */
  .post-footer {
    margin-top: var(--space-section);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    transition: color var(--duration-fast);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .series-nav {
    margin-top: var(--space-8);
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-secondary);
  }

  .series-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-4);
  }

  .series-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .series-link {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .series-link:hover {
    color: var(--color-accent);
  }

  .series-link.disabled {
    opacity: 0.6;
  }

  .share-section {
    margin-top: var(--space-8);
  }

  .share-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }

  .share-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .share-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    cursor: pointer;
  }

  .share-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .share-btn {
    font: inherit;
  }

  .share-tip {
    margin-top: var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  .subscribe-wrap {
    margin-top: var(--space-8);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .post-layout {
      grid-template-columns: 1fr;
    }

    .post-sidebar {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: var(--text-3xl);
    }

    .post-content {
      font-size: var(--text-base);
    }

    .series-links {
      grid-template-columns: 1fr;
    }
  }
</style>
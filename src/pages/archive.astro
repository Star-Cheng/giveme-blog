---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const base = import.meta.env.BASE_URL;

const grouped = posts.reduce((acc, post) => {
  const year = post.data.date.getFullYear();
  const month = post.data.date.getMonth() + 1;
  const key = `${year}-${String(month).padStart(2, '0')}`;

  if (!acc[key]) {
    acc[key] = [];
  }

  acc[key].push(post);
  return acc;
}, {} as Record<string, typeof posts>);

const archiveGroups = Object.entries(grouped).map(([key, items]) => {
  const [year, month] = key.split('-');
  return {
    key,
    label: `${year} 年 ${month} 月`,
    items,
  };
});
---

<BaseLayout title="归档 - 技术随笔" description="按时间轴查看所有技术文章">
  <section class="archive-page">
    <div class="container">
      <header class="page-header">
        <h1 class="page-title">归档</h1>
        <p class="page-subtitle">按时间轴浏览全部 {posts.length} 篇文章</p>
      </header>

      <div class="timeline">
        {archiveGroups.map(group => (
          <section class="timeline-group" id={group.key}>
            <h2 class="group-title">{group.label}</h2>
            <ul class="group-list">
              {group.items.map(post => (
                <li class="group-item">
                  <time class="post-date" datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('zh-CN', {
                      month: '2-digit',
                      day: '2-digit',
                    })}
                  </time>
                  <a href={`${base}blog/${post.id}`} class="post-link">
                    <span class="post-title">{post.data.title}</span>
                    <span class="post-desc">{post.data.description}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .archive-page {
    padding: var(--space-section) 0;
  }

  .page-header {
    margin-bottom: var(--space-12);
    text-align: center;
  }

  .page-title {
    margin-bottom: var(--space-3);
  }

  .page-subtitle {
    color: var(--color-text-subtle);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
    max-width: 900px;
    margin: 0 auto;
  }

  .timeline-group {
    padding: var(--space-6);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .group-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .group-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .group-item {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: var(--space-4);
    align-items: start;
  }

  .post-date {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
    margin-top: 2px;
  }

  .post-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    color: var(--color-text);
  }

  .post-link:hover .post-title {
    color: var(--color-accent);
  }

  .post-title {
    font-size: var(--text-base);
    font-weight: 600;
    transition: color var(--duration-fast);
  }

  .post-desc {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  @media (max-width: 640px) {
    .group-item {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }
</style>

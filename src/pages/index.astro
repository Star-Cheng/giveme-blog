---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latestPosts = posts.slice(0, 3);
const featuredPost = latestPosts[0];
const sidePosts = latestPosts.slice(1);
const base = import.meta.env.BASE_URL;
const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title="机器人控制实战笔记 - RobotControl.dev">
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <span class="hero-badge">从理论到真机</span>
        <h1 class="hero-title">
          <span>机器人控制</span>
          <span class="accent">实战笔记</span>
        </h1>
        <p class="hero-subtitle">
          专注运动规划、强化学习、Sim2Real 领域，<br />
          分享从算法理论到工业落地的完整工程经验。
        </p>
        <div class="hero-actions">
          <a href={`${base}blog`} class="btn btn-primary">浏览文章</a>
          <a href={`${base}about`} class="btn btn-ghost">关于我</a>
        </div>
        <div class="hero-arrow" aria-hidden="true">⌄</div>
      </div>
    </div>
  </section>

  <section class="latest">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="section-kicker">技术笔记</p>
          <h2>最新文章</h2>
        </div>
        <a href={`${base}blog`} class="all-link">查看全部 →</a>
      </div>

      <div class="latest-grid">
        {featuredPost && (
          <a href={`${base}blog/${featuredPost.id}`} class="article-card article-card-main">
            <span class="article-type">{featuredPost.data.category ?? '技术实战'}</span>
            <h3>{featuredPost.data.title}</h3>
            <p>{featuredPost.data.description}</p>
            <div class="article-tags">
              {featuredPost.data.tags.slice(0, 3).map(tag => (
                <span>{tag}</span>
              ))}
              {featuredPost.data.tags.length > 3 && <span>+{featuredPost.data.tags.length - 3}</span>}
            </div>
            <div class="article-meta">
              <span>{dateFormatter.format(featuredPost.data.date)}</span>
              <span>·</span>
              <span>{featuredPost.data.readingMinutes ?? 18} 分钟</span>
            </div>
          </a>
        )}

        <div class="latest-side">
          {sidePosts.map(post => (
            <a href={`${base}blog/${post.id}`} class="article-card">
              <span class="article-type">{post.data.category ?? '技术笔记'}</span>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <div class="article-tags">
                {post.data.tags.slice(0, 3).map(tag => (
                  <span>{tag}</span>
                ))}
                {post.data.tags.length > 3 && <span>+{post.data.tags.length - 3}</span>}
              </div>
              <div class="article-meta">
                <span>{dateFormatter.format(post.data.date)}</span>
                <span>·</span>
                <span>{post.data.readingMinutes ?? 18} 分钟</span>
              </div>
            </a>
          ))}
        </div>
      </div>
      {!latestPosts.length && <p class="latest-empty">还没有发布文章，先去写第一篇吧。</p>}
    </div>
  </section>

  <section class="category-showcase">
    <div class="container">
      <header class="showcase-header">
        <h2>技术分类</h2>
        <p>覆盖机器人控制算法的核心领域，从理论到实践</p>
      </header>

      <div class="category-grid">
        <a href={`${base}blog`} class="category-card category-plan">
          <span class="category-icon">↗</span>
          <h3>运动规划</h3>
          <p>轨迹规划、插值算法、避障策略</p>
        </a>
        <a href={`${base}blog`} class="category-card category-rl">
          <span class="category-icon">⎇</span>
          <h3>强化学习</h3>
          <p>Policy Gradient、DQN、Transformer</p>
        </a>
        <a href={`${base}blog`} class="category-card category-sim">
          <span class="category-icon">◎</span>
          <h3>Sim2Real</h3>
          <p>域随机化、领域适应、系统辨识</p>
        </a>
        <a href={`${base}blog`} class="category-card category-robot">
          <span class="category-icon">◻</span>
          <h3>机器人仿真</h3>
          <p>Gazebo、Webots、ROS2仿真</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: 68vh;
    display: grid;
    place-items: center;
    border-bottom: 1px solid rgba(74, 85, 104, 0.25);
  }

  .hero-inner {
    text-align: center;
    max-width: 780px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid rgba(0, 212, 168, 0.35);
    border-radius: 999px;
    background: rgba(0, 212, 168, 0.08);
    color: #37dfba;
    font-size: 0.82rem;
    padding: 6px 14px;
    margin-bottom: 24px;
  }

  .hero-title {
    font-size: clamp(2.6rem, 5.5vw, 4.8rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .hero-title span { display: block; }
  .hero-title .accent { color: #00d4a8; }

  .hero-subtitle {
    color: #8f9bb0;
    font-size: clamp(1rem, 1.4vw, 1.22rem);
    margin-bottom: 30px;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 108px;
    padding: 11px 18px;
    border-radius: 12px;
    border: 1px solid transparent;
    font-weight: 700;
    font-size: 0.93rem;
  }

  .btn-primary {
    background: linear-gradient(135deg, #00d4a8, #00c89e);
    color: #04131c;
  }

  .btn-ghost {
    border-color: rgba(135, 148, 171, 0.35);
    color: #dbe2ef;
    background: rgba(15, 23, 38, 0.7);
  }

  .hero-arrow {
    color: #6f7b91;
    font-size: 1.1rem;
  }

  .latest {
    padding: var(--space-section) 0 2.8rem;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
    gap: 1rem;
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #00cda5;
    font-size: 0.85rem;
    margin: 0 0 6px;
  }

  .section-kicker::before {
    content: '';
    width: 14px;
    height: 14px;
    border: 1px solid rgba(0, 212, 168, 0.42);
    border-radius: 4px;
    background: radial-gradient(circle at 30% 30%, rgba(0, 212, 168, 0.55), rgba(0, 212, 168, 0.08));
  }

  .section-head h2 {
    font-size: clamp(2.1rem, 3.8vw, 3.2rem);
    line-height: 1.1;
  }

  .all-link {
    color: #c8d3e3;
    border: 1px solid rgba(116, 128, 150, 0.35);
    border-radius: 10px;
    padding: 8px 14px;
    font-size: 0.9rem;
  }

  .all-link:hover {
    color: #00d4a8;
    border-color: rgba(0, 212, 168, 0.45);
  }

  .latest-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 18px;
    align-items: stretch;
  }

  .latest-side {
    display: grid;
    gap: 18px;
    grid-template-rows: 1fr 1fr;
  }

  .article-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    border: 1px solid rgba(58, 70, 92, 0.45);
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(12, 19, 32, 0.96), rgba(10, 15, 26, 0.96));
    padding: 1.35rem 1.35rem 1.2rem;
    transition: border-color .2s ease, transform .2s ease, box-shadow .2s ease;
    min-height: 260px;
  }

  .article-card:hover {
    border-color: rgba(0, 212, 168, 0.48);
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(1, 12, 23, 0.45);
  }

  .article-type {
    display: inline-block;
    font-size: 0.74rem;
    color: #00d9ae;
    background: rgba(0, 212, 168, 0.09);
    border: 1px solid rgba(0, 212, 168, 0.24);
    border-radius: 999px;
    padding: 3px 10px;
    margin-bottom: 10px;
  }

  .article-card h3 {
    font-size: clamp(1.2rem, 1.5vw, 1.82rem);
    line-height: 1.35;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card p {
    margin: 0;
    color: #90a0b9;
    font-size: 0.94rem;
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-meta {
    margin-top: auto;
    padding-top: 14px;
    display: flex;
    gap: 8px;
    font-size: 0.8rem;
    color: #738097;
  }

  .article-tags {
    margin-top: 14px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .article-tags span {
    font-size: 0.73rem;
    color: #00d0a8;
    background: rgba(0, 212, 168, 0.08);
    border: 1px solid rgba(0, 212, 168, 0.22);
    border-radius: 999px;
    padding: 2px 8px;
  }

  .article-card-main {
    min-height: 278px;
  }

  .article-card-main p {
    -webkit-line-clamp: 3;
  }

  .latest-empty {
    margin: 16px 0 0;
    padding: 14px 16px;
    border: 1px dashed rgba(90, 101, 126, 0.4);
    border-radius: 12px;
    color: #8e9cb3;
  }

  .category-showcase {
    padding: var(--space-section) 0 2.5rem;
  }

  .showcase-header {
    text-align: center;
    margin-bottom: 28px;
  }

  .showcase-header h2 {
    font-size: clamp(2rem, 3.6vw, 3rem);
    margin-bottom: 10px;
  }

  .showcase-header p {
    margin: 0;
    color: #8c98ae;
    font-size: 1.05rem;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .category-card {
    min-height: 180px;
    border: 1px solid rgba(58, 70, 92, 0.45);
    border-radius: 24px;
    padding: 24px 22px;
    transition: transform .2s ease, border-color .2s ease;
  }

  .category-card:hover {
    transform: translateY(-2px);
    border-color: rgba(0, 212, 168, 0.48);
  }

  .category-plan { background: linear-gradient(140deg, rgba(0, 212, 168, 0.18), rgba(8, 25, 43, 0.9)); }
  .category-rl { background: linear-gradient(140deg, rgba(56, 189, 248, 0.2), rgba(15, 24, 44, 0.9)); }
  .category-sim { background: linear-gradient(140deg, rgba(168, 85, 247, 0.2), rgba(23, 21, 46, 0.9)); }
  .category-robot { background: linear-gradient(140deg, rgba(245, 158, 11, 0.24), rgba(30, 23, 13, 0.9)); }

  .category-icon {
    display: inline-flex;
    margin-bottom: 14px;
    color: #00e0b3;
    font-size: 1.65rem;
    font-weight: 700;
  }

  .category-card h3 {
    font-size: 2rem;
    margin-bottom: 10px;
  }

  .category-card p {
    margin: 0;
    color: #95a0b8;
    line-height: 1.6;
  }

  @media (max-width: 960px) {
    .latest-grid {
      grid-template-columns: 1fr;
    }

    .latest-side {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
    }

    .category-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .btn { width: min(300px, 100%); }

    .latest-side {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .section-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .category-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
